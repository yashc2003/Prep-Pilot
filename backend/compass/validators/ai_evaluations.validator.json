{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["interview_id", "answer_text"],
    "properties": {
      "interview_id": { "bsonType": "objectId" },
      "answer_text": { "bsonType": "string", "minLength": 1 },
      "score": { "bsonType": ["int", "long", "double", "decimal"] },
      "remarks": { "bsonType": "string" }
    }
  }
}

